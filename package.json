{
  "name": "bandana-favorites",
  "version": "0.1.0",
  "private": true,
  "description": "Bandana Faves \u2014 crowd-ranked best-of-NYC by food type (the food is the title, the place is the subtitle).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "seed": "tsx scripts/seed.ts",
    "recompute": "tsx scripts/recompute.ts",
    "test": "node --import tsx --test src/lib/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "corpus": "python3 scripts/ingest_corpus.py"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "maplibre-gl": "^4.7.1",
    "next": "^15.1.6",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
