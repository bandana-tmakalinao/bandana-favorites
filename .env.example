# Bandana Favorites — environment
# Copy to .env.local and fill in. EVERYTHING here is OPTIONAL for local dev:
# with none of it set, the app runs on an in-memory + JSON-file store, a keyless
# map style, local-disk photo uploads, and a lightweight cookie session.

# --- Data layer ---------------------------------------------------------------
# When set, the app uses Postgres (Drizzle) instead of the in-memory store.
# Render managed Postgres connection string. Requires the PostGIS extension.
# DATABASE_URL="postgres://user:pass@host:5432/bandana_favorites?sslmode=require"

# --- Map ----------------------------------------------------------------------
# MapLibre style URL. Defaults to the keyless CARTO Positron basemap (see src/lib/mapStyle.ts).
# Production: a Protomaps PMTiles style on R2, or a MapTiler style URL with a key.
# NEXT_PUBLIC_MAP_STYLE="https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY"

# --- Photo storage (Cloudflare R2, S3-compatible) -----------------------------
# When all are set, uploads use presigned PUT to R2 instead of local disk.
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="bandana-favorites"
# R2_PUBLIC_BASE_URL="https://<bucket>.r2.dev"

# --- Auth ---------------------------------------------------------------------
# Secret used to sign the session cookie. A dev default is used if unset; the app warns loudly
# in production when it's missing (sessions would be forgeable). Generate: openssl rand -base64 32
# SESSION_SECRET="change-me-in-production"

# Google OAuth (optional). With BOTH set, "Continue with Google" appears on /me and the
# /api/auth/google[/callback] routes activate. Without them, everything no-ops (name sign-in only).
#   1. Create a Web OAuth client: https://console.cloud.google.com/apis/credentials
#   2. Authorized redirect URI: https://<your-domain>/api/auth/google/callback
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Public https origin, used to build the OAuth redirect URI in production (falls back to request origin).
# NEXT_PUBLIC_SITE_URL="https://bandanafavorites.com"

# --- Ranking (optional overrides; defaults live in src/lib/config.ts) ---------
# RANKING_SHRINKAGE_M="40"
